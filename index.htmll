<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gharana Spices</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #fff8f0;
      text-align: center;
    }
    header {
      background-color: #FFD700;
      padding: 20px;
      color: black;
    }
    header img {
      width: 120px;
      margin-bottom: 10px;
    }
    h1 {
      margin: 5px 0;
    }
    .section {
      padding: 30px;
    }
    .products {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 15px;
      padding: 20px;
    }
    .card {
      background: white;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    footer {
      background: #f1f1f1;
      color: black;
      padding: 15px;
    }
  </style>
</head>

<body>

  <header>
    <!-- Logo -->
    <img src="WhatsApp Image 2026-03-27 at 12.34.56.jpg" alt="Gharana Spices Logo">
    <h1>Gharana Spices 🌶️</h1>
    <p>Your Taste, Our Responsibility</p>
  </header>

  <div class="section">
    <h2>🌿 Our Products</h2>
    <div class="products">
      <div class="card">🟡 Haldi Powder</div>
      <div class="card">🔴 Red Chilli Powder</div>
      <div class="card">🟤 Coriander Powder</div>
      <div class="card">🍏 Amla Powder</div>
    </div>
  </div>

  <footer>
    <p>© 2026 Gharana Spices | Homemade with ❤️</p>
  </footer>

</body>
</html>
